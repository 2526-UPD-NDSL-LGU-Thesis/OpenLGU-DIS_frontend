{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "transit-node": {
      "dependsOn": ["^transit-node"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^transit-node"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}